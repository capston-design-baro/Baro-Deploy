# Copy this file to .env.prod on the EC2 instance and fill real values.

POSTGRES_USER=baro
POSTGRES_PASSWORD=change-this-long-random-password
POSTGRES_DB=baro_db

SECRET_KEY=change-this-secret-key-min-32-characters
ENCRYPTION_KEY=change-this-fernet-key

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-mini
RAG_DB_URL=https://your-presigned-rag-db-url/chroma.sqlite3

# Vercel frontend origins allowed by the backend. Comma-separated.
# Example: https://baro-front-five.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=https://baro-front-five.vercel.app

# Host port exposed on EC2 for the backend API.
BACKEND_PORT=8000
